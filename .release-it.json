{
  "git": {
    "commitMessage": "chore(release): ${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "push": true,
    "tagAnnotation": "Release ${version}"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "hooks": {
    "after:release": "echo \"\\nTag v${version} pushed. CI will publish to npm and create the GitHub Release.\\nFollow the run at https://github.com/vladlenskiy/react-native-tdlib/actions\""
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits"
      },
      "infile": "CHANGELOG.md",
      "strictSemVer": true
    }
  }
}